# Trading Bot Environment Variables
# Copy this to .env and fill in your values

# Broker mode: "paper", "demo", or "live"
BROKER_MODE=paper

# IG API credentials — get API key from https://labs.ig.com/
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_API_KEY=your_api_key_here
IG_ACC_TYPE=DEMO
IG_ACC_NUMBER=your_spread_bet_account_number

# IBKR credentials — requires TWS or IB Gateway running with API enabled
# Paper: port 7497 (TWS) or 4002 (Gateway)
# Live:  port 7496 (TWS) or 4001 (Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=
IBKR_CURRENCY=USD

# Notifications (optional)
NOTIFY_EMAIL=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
