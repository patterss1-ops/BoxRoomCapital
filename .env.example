# Trading Bot Environment Variables
# Copy this to .env and fill in your values

# Broker mode: "paper", "demo", or "live"
BROKER_MODE=paper

# IG API credentials — get API key from https://labs.ig.com/
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_API_KEY=your_api_key_here
IG_ACC_TYPE=DEMO
IG_ACC_NUMBER=your_spread_bet_account_number

# Notifications (optional)
NOTIFY_EMAIL=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# AI Panel API Keys (G-003)
XAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Logging
LOG_LEVEL=INFO

# Docker / Deployment (H-004)
CONTROL_PLANE_PORT=8000
