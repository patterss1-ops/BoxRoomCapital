# Trading Bot Environment Variables
# Copy this to .env and fill in your values

# Broker mode: "paper", "demo", or "live"
BROKER_MODE=paper

# IG API credentials — get API key from https://labs.ig.com/
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_API_KEY=your_api_key_here
IG_ACC_TYPE=DEMO
IG_ACC_NUMBER=your_spread_bet_account_number
IG_DEMO_USERNAME=
IG_DEMO_PASSWORD=
IG_DEMO_API_KEY=
IG_DEMO_ACC_NUMBER=
IG_LIVE_USERNAME=
IG_LIVE_PASSWORD=
IG_LIVE_API_KEY=
IG_LIVE_ACC_NUMBER=
# Optional: attach broker-side protective stops to new IG positions.
# Default is false so live/manual execution does not silently inherit market-specific stop distances.
IG_ATTACH_PROTECTIVE_STOPS=false
IG_PROTECTIVE_STOP_FACTOR=2.0

# Notifications
NOTIFICATIONS_ENABLED=false
NOTIFY_EMAIL=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# AI Panel API Keys (G-003)
XAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Data feed API keys
# Seeking Alpha — scraper login (replaces RapidAPI)
SA_EMAIL=
SA_PASSWORD=
# SA_RAPIDAPI_KEY= (deprecated — use SA_EMAIL/SA_PASSWORD instead)
FRED_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Scraper credentials (optional — for UK director dealings and earnings)
SHARESCOPE_EMAIL=
SHARESCOPE_PASSWORD=
KOYFIN_EMAIL=
KOYFIN_PASSWORD=

# Logging
LOG_LEVEL=INFO

# Research system PostgreSQL
RESEARCH_DB_DSN=postgresql://localhost:5432/boxroom_research

# Docker / Deployment (H-004)
CONTROL_PLANE_PORT=8000

# Pipeline automation — set to true for always-on operation
ORCHESTRATOR_ENABLED=false
ORCHESTRATOR_DRY_RUN=true
AI_PANEL_ENABLED=false
DISPATCHER_ENABLED=false
ENGINE_A_ENABLED=false
ENGINE_B_ENABLED=false
RESEARCH_SYSTEM_ACTIVE=false
ENGINE_A_INTERVAL_SECONDS=300
ENGINE_A_CAPITAL_BASE=750000
DISPATCHER_INTERVAL_SECONDS=60

# Crypto (Kraken)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# X / Twitter API — get keys from https://console.x.com
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# Intraday event loop
INTRADAY_ENABLED=false
INTRADAY_POLL_SECONDS=300
INTRADAY_TICKERS=SPY,QQQ

# Strategy orchestration (O-003)
ENABLE_IG_ORCHESTRATOR_STRATEGIES=true

# Webhook intake hardening
TRADINGVIEW_WEBHOOK_TOKEN=
TRADINGVIEW_WEBHOOK_MAX_PAYLOAD_BYTES=65536
SA_BROWSER_CAPTURE_MAX_AGE_SECONDS=86400
TRADINGVIEW_MAX_SIGNAL_AGE_SECONDS=600
TRADINGVIEW_ENABLED_STRATEGIES=ibs_spreadbet_long,ibs_spreadbet_short

# Telegram bot webhook (for forwarding X/Twitter content)
# Set up: POST https://api.telegram.org/bot<TOKEN>/setWebhook?url=<YOUR_URL>/api/webhooks/telegram
# The bot will auto-analyze any forwarded X links or text messages

# Daily market data refresh (Engine A fuel)
MARKET_DATA_REFRESH_ENABLED=false
MARKET_DATA_REFRESH_HOUR=20
MARKET_DATA_REFRESH_MINUTE=0

# Feed aggregator (Engine B automated intake)
FEED_AGGREGATOR_ENABLED=false
FEED_AGGREGATOR_TICKERS=SPY,QQQ,AAPL,MSFT,NVDA
FEED_AGGREGATOR_FINNHUB_INTERVAL=300
FEED_AGGREGATOR_AV_INTERVAL=900
FEED_AGGREGATOR_FRED_INTERVAL=3600
FEED_AGGREGATOR_FRED_SERIES=T10Y2Y,DFF,BAMLH0A0HYM2
FEED_AGGREGATOR_TV_INTERVAL=600
FEED_AGGREGATOR_TV_ENABLED=true

# Portfolio analytics API (O-005)
PORTFOLIO_ANALYTICS_DEFAULT_DAYS=90
PORTFOLIO_ANALYTICS_MAX_DAYS=365
PORTFOLIO_ANALYTICS_ROLLING_WINDOW=21
PORTFOLIO_ANALYTICS_RISK_FREE_RATE=0.0

# Advisory module
ADVISOR_ENABLED=true
ADVISOR_MODEL=claude-opus-4-6
ADVISOR_MAX_CONTEXT_MESSAGES=20
ADVISOR_MAX_MEMORY_ITEMS=15
ADVISOR_SESSION_TIMEOUT_HOURS=4
ADVISOR_MEMORY_EXTRACTION_ENABLED=true

# RSS feed aggregator (advisory context)
RSS_AGGREGATOR_ENABLED=false
RSS_POLL_INTERVAL=1800
# RSS_FEEDS_OVERRIDE={"custom_feed":"https://example.com/rss"}

# X/Twitter bookmarks polling
X_BOOKMARKS_ENABLED=false
X_BOOKMARKS_POLL_INTERVAL=1800

# Advisory proactive alerts
ADVISOR_WEEKLY_REVIEW_ENABLED=false
ADVISOR_WEEKLY_REVIEW_DAY=6
ADVISOR_WEEKLY_REVIEW_HOUR=18
ADVISOR_DAILY_CHECK_ENABLED=false
ADVISOR_DRAWDOWN_ALERT_PCT=10.0
